{
  "id": "addAdminBanner",
  "editableByAdmins": true,
  "options": {
    "mode": "onChange"
  },
  "fields": [
    {
      "id": "bannerTitle",
      "type": "text",
      "validation": "text",
      "props": {
        "label": "Title text",
        "placeholder": "New banner title"
      }
    },
    {
      "id": "bannerDescription",
      "type": "textarea",
      "validation": "text",
      "props": {
        "label": "Description text",
        "hint": [
          {
            "type": "span",
            "content": "Formatting is supported with these HTML tags:"
          },
          {
            "type": "ul",
            "props": {
              "style": {
                "paddingLeft": "1rem"
              }
            },
            "children": [
              {
                "type": "li",
                "content": "&lt;strong&gt;"
              },
              {
                "type": "li",
                "content": "&lt;em&gt;"
              },
              {
                "type": "li",
                "content": "&lt;p&gt;"
              },
              {
                "type": "li",
                "content": "&lt;ul&gt;"
              },
              {
                "type": "li",
                "content": "&lt;ol&gt;"
              },
              {
                "type": "li",
                "content": "&lt;li&gt;"
              },
              {
                "type": "li",
                "content": "&lt;a&gt;"
              }
            ]
          }
        ],
        "placeholder": "New banner description"
      }
    },
    {
      "id": "bannerLink",
      "type": "text",
      "validation": "urlOptional",
      "props": {
        "label": "Link",
        "styleAsOptional": true
      }
    },
    {
      "id": "bannerStartDate",
      "type": "date",
      "validation": "date",
      "props": {
        "label": "Start date",
        "timetype": "startDate"
      }
    },
    {
      "id": "bannerEndDate",
      "type": "date",
      "validation": {
        "type": "endDate",
        "dependentFieldName": "bannerStartDate"
      },
      "props": {
        "label": "End date",
        "timetype": "endDate"
      }
    }
  ]
}
