{
  "name": "app-api",
  "version": "1.0.0",
  "description": "",
  "license": "CC0-1.0",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enterprise-CMCS/macpro-mdct-mcr.git"
  },
  "main": "handler.js",
  "scripts": {
    "build:json": "ts-node utils/routes/build-json",
    "coverage": "jest --coverage",
    "db:seed": "ts-node db/seed",
    "test": "jest",
    "test-watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "~3.1012.0",
    "@aws-sdk/client-s3": "~3.1012.0",
    "@aws-sdk/lib-dynamodb": "~3.1012.0",
    "@aws-sdk/util-dynamodb": "~3.996.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.4.1",
    "jsdom": "^24.1.3",
    "jwt-decode": "^3.1.2",
    "jwt-encode": "^1.0.1",
    "kafkajs": "^2.2.4",
    "ksuid": "^3.0.0",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/jest": "29.5.14",
    "@types/jsdom": "^21.1.7",
    "@types/jwt-encode": "^1.0.3",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.19.0",
    "@types/prompts": "^2.4.9",
    "aws-sdk-client-mock": "~4.1.0",
    "jest": "30.3.0",
    "prompts": "^2.4.2",
    "ts-jest": "29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "handlers/**/*.{ts,tsx}",
      "utils/**/*.{ts,tsx}",
      "!utils/constants/*",
      "!utils/testing/*",
      "!utils/types/*"
    ],
    "coverageReporters": [
      "json",
      [
        "lcov",
        {
          "projectRoot": "../../"
        }
      ],
      "text",
      "text-summary"
    ],
    "globals": {
      "isolatedModules": true
    },
    "moduleDirectories": [
      "node_modules"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.build/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/utils/testing/setupJest.ts"
    ],
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "verbose": true
  }
}
